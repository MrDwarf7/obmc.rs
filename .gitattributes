# Auto-detect text vs binary; force LF for all text files
* text=auto eol=lf

# Explicit text types
*.rs     text eol=lf
*.toml   text eol=lf
*.yaml   text eol=lf
*.yml    text eol=lf
*.md     text eol=lf
*.sh     text eol=lf
*.json   text eol=lf
*.gitattributes text eol=lf
*.gitignore    text eol=lf

# Binary files
*.png    binary
*.jpg    binary
*.jpeg   binary
*.gif    binary
*.ico    binary
*.zip    binary
*.tar.gz binary
